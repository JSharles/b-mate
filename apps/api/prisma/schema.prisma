// See docs/PRODUCT.md for the full data model rationale and business rules.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ProjectMemberRole {
  client
  contributor
}

model User {
  id           String  @id @default(uuid()) @db.Uuid
  firstName    String  @map("first_name")
  lastName     String  @map("last_name")
  email        String  @unique
  passwordHash String  @map("password_hash")
  company      String?
  address      String?
  phone        String?
  image        String?
  bio          String?
  github       String?
  socials      String?
  roleTitle    String? @map("role_title")
  status       String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  memberships   ProjectMember[]
  assignedTasks Task[]
  sessions      Session[]

  @@map("users")
}

// The session id doubles as the bearer secret sent to the client in an
// httpOnly cookie — it's a uuid (cryptographically random), no separate
// token field needed. Deleting the row logs the session out immediately.
model Session {
  id     String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid

  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Project {
  id                 String  @id @default(uuid()) @db.Uuid
  title              String
  status             String?
  progressPercentage Int?    @map("progress_percentage")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members     ProjectMember[]
  invitations Invitation[]
  tasks       Task[]

  @@map("projects")
}

// Pivot table: this is where project access is granted. See docs/PRODUCT.md
// "Business rules" — role is a security field, and a project must always
// keep at least one admin. Both are enforced in application code, not here.
model ProjectMember {
  id        String            @id @default(uuid()) @db.Uuid
  projectId String            @map("project_id") @db.Uuid
  userId    String            @map("user_id") @db.Uuid
  role      ProjectMemberRole
  isAdmin   Boolean           @default(false) @map("is_admin")

  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

// Keyed by email, not user_id: the invitee may not have an account yet.
// `token` must stay cryptographically random (see docs/PRODUCT.md).
model Invitation {
  id        String            @id @default(uuid()) @db.Uuid
  projectId String            @map("project_id") @db.Uuid
  email     String
  role      ProjectMemberRole
  isAdmin   Boolean           @default(false) @map("is_admin")
  token     String            @unique
  status    String
  expiresAt DateTime          @map("expires_at")

  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("invitations")
}

model Task {
  id          String  @id @default(uuid()) @db.Uuid
  projectId   String  @map("project_id") @db.Uuid
  assigneeId  String? @map("assignee_id") @db.Uuid
  title       String
  description String?
  status      String?
  duration    Int?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee User?   @relation(fields: [assigneeId], references: [id], onDelete: SetNull)

  @@map("tasks")
}
