# Copy to .env.local for local development: cp .env.example .env.local
# In production (Vercel/Railway), these are set via the platform dashboard, not a committed file.

NEXT_PUBLIC_API_URL="http://localhost:3001"
# Used for canonical/hreflang URLs and the sitemap. Set to the real domain in prod.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
